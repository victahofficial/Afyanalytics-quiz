generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  member
  leader
  admin
  superadmin
}

enum PostStatus {
  pending
  approved
  rejected
}

enum NoticeType {
  crew
  general
  event
}

model User {
  id           Int      @id @default(autoincrement())
  fullName     String
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  status       String   @default("pending")
  role         Role     @default(member)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  posts      Post[]
  photos     Photo[]
  notices    MeetingNotice[]   @relation("NoticeCreator")
  recipients NoticeRecipient[]
  downloads  DownloadLog[]
  documents  Document[]
  auditLogs  AuditLog[]        @relation("UserAuditLogs")
}

model Post {
  id        Int        @id @default(autoincrement())
  title     String
  content   String
  status    PostStatus @default(pending)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  authorId Int
  author   User @relation(fields: [authorId], references: [id])
}

model Photo {
  id           Int      @id @default(autoincrement())
  title        String
  filename     String
  originalName String
  mimeType     String
  size         Int
  externalUrl  String?
  createdAt    DateTime @default(now())

  uploaderId Int
  uploader   User @relation(fields: [uploaderId], references: [id])
}

model MeetingNotice {
  id          Int        @id @default(autoincrement())
  title       String
  message     String
  type        NoticeType
  meetingDate DateTime?
  sendEmail   Boolean    @default(true)
  sendSms     Boolean    @default(false)
  createdAt   DateTime   @default(now())

  createdById Int
  createdBy   User @relation("NoticeCreator", fields: [createdById], references: [id])

  recipients NoticeRecipient[]
}

model NoticeRecipient {
  id          Int       @id @default(autoincrement())
  sentEmail   Boolean   @default(false)
  sentSms     Boolean   @default(false)
  emailSentAt DateTime?
  smsSentAt   DateTime?

  noticeId Int
  userId   Int
  notice   MeetingNotice @relation(fields: [noticeId], references: [id])
  user     User          @relation(fields: [userId], references: [id])

  @@unique([noticeId, userId])
}

model DownloadLog {
  id        Int      @id @default(autoincrement())
  kind      String
  targetId  Int
  createdAt DateTime @default(now())

  userId Int?
  user   User? @relation(fields: [userId], references: [id])
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  category    String
  price       Int
  stock       Int      @default(0)
  description String
  imagePath   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  entity    String
  entityId  Int?
  createdAt DateTime @default(now())

  userId    Int
  user      User     @relation("UserAuditLogs", fields: [userId], references: [id])
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Document {
  id           Int      @id @default(autoincrement())
  title        String
  filename     String
  originalName String
  mimeType     String
  size         Int
  category     String   // e.g. "downloads", "constitution"
  isPublic     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  uploaderId   Int
  uploader     User     @relation(fields: [uploaderId], references: [id])
}

model PageContent {
  slug      String   @id
  title     String
  eyebrow   String
  body      String
  updatedAt DateTime @updatedAt
}

model FooterLink {
  id        Int      @id @default(autoincrement())
  title     String
  url       String
  column    Int      // 1: About, 2: Quick Links, 3: Useful Links, 4: Opportunities
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model SocialAccount {
  id        Int      @id @default(autoincrement())
  platform  String   // e.g. "Facebook", "X", "Instagram"
  url       String
  icon      String?
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model SocialPost {
  id        Int      @id @default(autoincrement())
  platform  String
  content   String
  postUrl   String?
  imageUrl  String?
  postedAt  DateTime @default(now())
  createdAt DateTime @default(now())
}
